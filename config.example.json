{
  "server": {
    "port": 3000
  },
  "immich": {
    "baseUrl": "http://192.168.1.x:2283",
    "apiKey": "your-immich-api-key",
    "albumId": "uuid-of-shared-album",
    "slideshowIntervalSeconds": 15
  },
  "homeAssistant": {
    "baseUrl": "http://homeassistant.local:8123",
    "token": "your-long-lived-access-token",
    "weatherEntity": "weather.home",
    "cameraEntity": "camera.reolink_front_door",
    "cameraTriggerEntities": [
      "binary_sensor.reolink_front_door_visitor",
      "binary_sensor.reolink_front_door_person"
    ],
    "cameraAutoHideSeconds": 30,
      "mediaPlayerEntity": "media_player.kitchen_speaker",
      "moonEntity": "sensor.moon_phase"
  },
  "display": {
    "clockFormat24h": false,
    "temperatureUnit": "F"
  },
  "specialViews": {
    "intervalPhotos": 20,
    "dashboardDurationSeconds": 120,
    "flightAwareDurationSeconds": 120,
    "flightAwareUrl": "http://192.168.10.71:8080/",
    "sensorEntities": [
      { "entityId": "sensor.office_aqara_temp_temperature", "label": "Office" },
      { "entityId": "sensor.down_bath_aqara_temperature_sensor_temperature", "label": "Bathroom" },
      { "entityId": "sensor.temperature_dna_room",     "label": "DNA Bedroom" },
      { "entityId": "sensor.temperature_aiden_room",     "label": "Aiden Bedroom" },
      { "entityId": "sensor.temperature_elizabeth_room",     "label": "Elizabeth Bedroom" },
      { "entityId": "sensor.basement_aqara_temperature_sensor_temperature",      "label": "Basement" }
    ]
  }
}
